VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Set to "true" after enabling Google/Apple in Supabase Dashboard → Authentication → Providers
VITE_ENABLE_OAUTH="false"

# Web Push (generate with: npx web-push generate-vapid-keys)
# Public key goes in .env — private key goes in Supabase Edge Function secrets
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"

# Supabase Edge Function secrets (Dashboard → Project Settings → Edge Functions → Secrets)
# Required for support & contact form emails (inbox set via SUPPORT_TEAM_EMAIL secret)
# RESEND_API_KEY="re_..."
# SUPPORT_TEAM_EMAIL="reelcruiter@gmail.com"
# Optional custom sender after verifying a domain in Resend
# SUPPORT_FROM_EMAIL="ReelCruiter Support <support@yourdomain.com>"
# SITE_URL="https://your-production-domain.com"
# VAPID_PUBLIC_KEY="same as VITE_VAPID_PUBLIC_KEY"
# VAPID_PRIVATE_KEY="from web-push generate-vapid-keys"
# OPENAI_API_KEY="sk-..." (required for AI-generated About text and skills from CV uploads)
# OPENAI_MODEL="gpt-4o-mini" (optional)
